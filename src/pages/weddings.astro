---
import '../styles/global.css';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import BridalForm from '../components/BridalForm.astro';
import { getEntry } from 'astro:content';

const weddings = await getEntry('site', 'weddings');
const { heading, intro, packages } = weddings.data;

Base;
---

<Base>
  <Nav />
  
  <section class="relative min-h-[40vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-beige/20 to-green/20"></div>
    <div class="absolute inset-0 bg-black/50"></div>
    
    <svg class="absolute inset-0 w-full h-full opacity-[0.03]">
      <filter id="noise">
        <feTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="4" stitchTiles="stitch" />
      </filter>
      <rect width="100%" height="100%" filter="url(#noise)" />
    </svg>

    <div class="relative z-10 max-w-[1200px] mx-auto px-6 text-center">
      <h1 class="font-display text-5xl md:text-7xl text-beige mb-6">{heading}</h1>
      <p class="font-body text-text-muted max-w-2xl mx-auto text-lg md:text-xl">
        {intro}
      </p>
    </div>
  </section>
  
  <section class="py-16 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <h2 class="font-display text-4xl md:text-5xl text-beige text-center mb-16">Bridal Packages</h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {packages.map(pkg => (
          <article class="bg-surface rounded-2xl border border-border p-6 hover:shadow-lg transition-shadow">
            <h3 class="font-display text-2xl text-beige mb-2">{pkg.name}</h3>
            <p class="font-display text-xl text-green mb-4">{pkg.price}</p>
            <p class="font-body text-text-muted mb-6">{pkg.description}</p>
            
            <ul class="space-y-3">
              {pkg.includes.map(item => (
                <li class="flex items-start gap-3 font-body text-text">
                  <svg class="w-5 h-5 text-green mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>
  
  <BridalForm />
</Base>
