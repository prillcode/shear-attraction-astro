---
import { getEntry } from 'astro:content';

const weddings = await getEntry('site', 'weddings');
const { contactName, contactNote } = weddings.data;
const salon = await getEntry('site', 'salon');
const { phone } = salon.data;
---

<section class="py-24 bg-surface">
  <div class="max-w-[1200px] mx-auto px-6">
    <h2 class="font-display text-4xl md:text-5xl text-beige text-center mb-4">Get in Touch with {contactName}</h2>
    <p class="font-body text-text-muted text-center max-w-2xl mx-auto mb-12">
      {contactNote}
    </p>
    
    <div class="max-w-2xl mx-auto">
      <form id="bridal-form" action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-6">
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
        <input type="hidden" name="_subject" value="New Bridal Inquiry — Shear Attraction Salon" />
        
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label for="fullName" class="block font-body text-text mb-2">Full Name *</label>
            <input
              type="text"
              id="fullName"
              name="fullName"
              required
              class="w-full bg-surface-alt border border-border rounded-lg px-4 py-3 text-text focus:outline-none focus:border-green transition-colors"
            />
          </div>
          
          <div>
            <label for="email" class="block font-body text-text mb-2">Email Address *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-surface-alt border border-border rounded-lg px-4 py-3 text-text focus:outline-none focus:border-green transition-colors"
            />
          </div>
        </div>
        
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label for="phone" class="block font-body text-text mb-2">Phone Number *</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              class="w-full bg-surface-alt border border-border rounded-lg px-4 py-3 text-text focus:outline-none focus:border-green transition-colors"
            />
          </div>
          
          <div>
            <label for="weddingDate" class="block font-body text-text mb-2">Wedding Date *</label>
            <input
              type="date"
              id="weddingDate"
              name="weddingDate"
              required
              class="w-full bg-surface-alt border border-border rounded-lg px-4 py-3 text-text focus:outline-none focus:border-green transition-colors"
            />
          </div>
        </div>
        
        <div>
          <label for="venue" class="block font-body text-text mb-2">Wedding Location / Venue *</label>
          <input
            type="text"
            id="venue"
            name="venue"
            required
            class="w-full bg-surface-alt border border-border rounded-lg px-4 py-3 text-text focus:outline-none focus:border-green transition-colors"
          />
        </div>
        
        <div>
          <label for="partySize" class="block font-body text-text mb-2">Party Size (# needing hair) *</label>
          <input
            type="number"
            id="partySize"
            name="partySize"
            min="1"
            required
            class="w-full bg-surface-alt border border-border rounded-lg px-4 py-3 text-text focus:outline-none focus:border-green transition-colors"
          />
        </div>
        
        <div>
          <label class="block font-body text-text mb-3">Services needed *</label>
          <div class="space-y-2">
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" name="services" value="Bride" class="w-4 h-4 accent-green" required />
              <span class="font-body text-text">Bride</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" name="services" value="Bridesmaids" class="w-4 h-4 accent-green" />
              <span class="font-body text-text">Bridesmaids</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" name="services" value="Mother of Bride" class="w-4 h-4 accent-green" />
              <span class="font-body text-text">Mother of Bride</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" name="services" value="Mother of Groom" class="w-4 h-4 accent-green" />
              <span class="font-body text-text">Mother of Groom</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" name="services" value="Flower Girls / Children" class="w-4 h-4 accent-green" />
              <span class="font-body text-text">Flower Girls / Children</span>
            </label>
          </div>
        </div>
        
        <div>
          <label for="message" class="block font-body text-text mb-2">Message / Additional Details</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            class="w-full bg-surface-alt border border-border rounded-lg px-4 py-3 text-text focus:outline-none focus:border-green transition-colors resize-none"
          ></textarea>
        </div>
        
        <div>
          <label for="referral" class="block font-body text-text mb-2">How did you hear about us?</label>
          <select
            id="referral"
            name="referral"
            class="w-full bg-surface-alt border border-border rounded-lg px-4 py-3 text-text focus:outline-none focus:border-green transition-colors"
          >
            <option value="">Select an option</option>
            <option value="Google">Google</option>
            <option value="Instagram">Instagram</option>
            <option value="Facebook">Facebook</option>
            <option value="Word of mouth">Word of mouth</option>
            <option value="Returning client">Returning client</option>
            <option value="Other">Other</option>
          </select>
        </div>
        
        <button
          type="submit"
          class="w-full rounded-full bg-green text-bg font-medium px-6 py-3 hover:bg-green-light transition-colors"
        >
          Send Inquiry
        </button>
      </form>
      
      <div id="form-success" class="hidden text-center py-8">
        <div class="text-green mb-4">
          <svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <p class="font-display text-2xl text-beige mb-2">Thank you!</p>
        <p class="font-body text-text-muted">
          {contactName} will be in touch within 24 hours to discuss your wedding vision.
        </p>
      </div>
      
      <div id="form-error" class="hidden text-center py-8">
        <div class="text-red-500 mb-4">
          <svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <p class="font-display text-2xl text-beige mb-2">Something went wrong</p>
        <p class="font-body text-text-muted">
          Please try again or call us directly at {phone}.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('bridal-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    
    const selectedServices = formData.getAll('services');
    if (selectedServices.length === 0) {
      alert('Please select at least one service');
      return;
    }
    
    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: { 'Accept': 'application/json' }
      });
      
      if (res.ok) {
        form.style.display = 'none';
        successMsg?.classList.remove('hidden');
      } else {
        errorMsg?.classList.remove('hidden');
      }
    } catch {
      errorMsg?.classList.remove('hidden');
    }
  });
</script>
