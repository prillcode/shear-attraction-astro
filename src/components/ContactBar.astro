---
import { getEntry } from 'astro:content';

const salon = await getEntry('site', 'salon');
const { instagram, facebook } = salon.data;
---

<section id="contact" class="bg-surface py-24">
  <div class="max-w-[1200px] mx-auto px-6">
    <h2 class="font-display text-4xl md:text-5xl text-beige text-center mb-16">Contact Us</h2>
    
    <div class="grid md:grid-cols-2 gap-12 mb-12">
      <div>
        <div class="space-y-6">
          <div>
            <h3 class="font-display text-beige text-xl mb-2">Address</h3>
            <p class="font-body text-text">685 Hogan Rd, Bangor</p>
            <p class="font-body text-text-muted text-sm mt-1">next to Bull Moose Music</p>
          </div>
          
          <div>
            <h3 class="font-display text-beige text-xl mb-2">Hours</h3>
            <div class="space-y-2">
              <div class="font-body text-text">
                <div>Monday - Saturday</div>
                <div class="text-text-muted text-sm">By Appointment Only. Walkins accepted as stylist availability permits.</div>
              </div>
              <div class="flex justify-between font-body text-text-muted">
                <span>Sunday</span>
                <span>Closed</span>
              </div>
            </div>
          </div>
          
          <div>
            <h3 class="font-display text-beige text-xl mb-2">Get in Touch</h3>
            <p class="font-body text-text-muted">
              Contact individual stylists via booking links above or call for availability.
            </p>
          </div>
        </div>
        
        <div class="flex gap-4 mt-8">
          <a href={instagram} target="_blank" rel="noopener" class="text-text hover:text-green transition-colors" aria-label="Instagram">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href={facebook} target="_blank" rel="noopener" class="text-text hover:text-green transition-colors" aria-label="Facebook">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
        
        <p class="mt-8 font-body text-text-muted">
          Planning a wedding? <a href="/weddings" class="text-green hover:text-green-light transition-colors">Learn about our bridal services →</a>
        </p>
      </div>
      
      <div>
        <iframe
          src="https://www.google.com/maps?q=685+Hogan+Rd+Bangor+ME&output=embed"
          width="100%"
          height="350"
          loading="lazy"
          class="rounded-xl border border-border"
          title="Google Maps"
        ></iframe>
      </div>
    </div>
  </div>
</section>
