---
const allImages = import.meta.glob('/public/images/gallery/*', { eager: true });
const images = Object.entries(allImages).map(([path, _module]) => ({
  path,
  src: path.replace('/public', ''),
}));
---

{images.length > 0 && (
<section id="gallery" class="py-24">
  <div class="max-w-[1200px] mx-auto px-6">
    <h2 class="font-display text-4xl md:text-5xl text-beige text-center mb-16">Our Work</h2>
    
    <div class="gallery-grid">
      {images.map((img, idx) => (
        <a href={img.src} class="gallery-item block" data-gallery-item={idx}>
          <img
            src={img.src}
            alt={`Gallery photo ${idx + 1}`}
            loading="lazy"
            class="w-full h-auto"
          />
        </a>
      ))}
    </div>
  </div>
</section>
)}

<style>
  .gallery-grid {
    columns: 1;
    column-gap: 1rem;
  }
  
  @media (min-width: 640px) {
    .gallery-grid {
      columns: 2;
    }
  }
  
  @media (min-width: 1024px) {
    .gallery-grid {
      columns: 3;
    }
  }
  
  .gallery-grid img {
    break-inside: avoid;
    margin-bottom: 1rem;
    border-radius: 0.75rem;
    width: 100%;
    transition: transform 0.3s ease;
  }
  
  .gallery-grid img:hover {
    transform: scale(1.02);
  }
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>

<script>
  declare const GLightbox: (options: { selector: string }) => void;
  GLightbox({ selector: '.gallery-item' });
</script>
